# このファイルをコピーして .env を作成してください:  cp .env.example .env

# ── 公開ポート（一般的でない 27xxx 帯。衝突したらここを変更）──
WORDPRESS_PORT=27080   # http://localhost:27080
MAILHOG_PORT=27025     # http://localhost:27025

# ── データベース ──
WORDPRESS_DB_NAME=mini4wd
WORDPRESS_DB_USER=mini4wd
WORDPRESS_DB_PASSWORD=mini4wd_pass
MYSQL_ROOT_PASSWORD=root_pass_change_me

# ── WordPress ──
WORDPRESS_DEBUG=1      # 1=デバッグ表示ON / 0=OFF
