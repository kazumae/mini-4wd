# 本番(デモ)用 env テンプレート
# サーバ上で `cp .env.prod.example .env` し、__CHANGE_ME__ を強力な乱数値に置き換える。
# 実体の .env は .gitignore 済みなので git には入らない。

# 公開ドメイン（Caddy / WordPress のサイトURLに使用）
SITE_DOMAIN=mini4wd.kazumae.net

# データベース
WORDPRESS_DB_NAME=mini4wd
WORDPRESS_DB_USER=mini4wd
WORDPRESS_DB_PASSWORD=__CHANGE_ME__
MYSQL_ROOT_PASSWORD=__CHANGE_ME__

# 本番はデバッグ表示OFF
WORDPRESS_DEBUG=0
